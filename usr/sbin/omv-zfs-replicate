#!/bin/bash
# ZFS replication: snapshot source and send to destination (local or remote via SSH).
# Usage: omv-zfs-replicate <dataset> <prefix> <dest> <type> <remotehost>
#                          <certref> <sshuser> <sshport> <recursive> <raw>
#                          [-r retention] [--bookmarks] [--no-snapshot]
#                          [-e always|onerror] [-c comment]
#
#   dataset       - source ZFS dataset (e.g. tank/data)
#   prefix        - snapshot name prefix (e.g. replicate)
#   dest          - destination dataset path (e.g. backup/data)
#   type          - "local" or "remote"
#   remotehost    - remote hostname/IP (ignored when type=local)
#   certref       - OMV SSH certificate UUID (ignored when type=local, empty = default key)
#   sshuser       - SSH user on remote (ignored when type=local)
#   sshport       - SSH port on remote (ignored when type=local)
#   recursive     - 1 to snapshot/send recursively, 0 otherwise
#   raw           - 1 to use zfs send -w (raw/encrypted), 0 otherwise
#   -r N          - keep N replication snapshots on source (0 = keep all); ignored with --no-snapshot
#   --bookmarks   - use ZFS bookmarks as incremental base; allows aggressive source pruning
#   --no-snapshot - do not create a new snapshot; replicate the most recent existing snapshot
#                   matching the prefix. Use when a separate snapshot job manages the snapshots.
#   -e            - email mode: "always" or "onerror"
#   -c            - email subject comment

set -euo pipefail

LOGFILE="/var/log/omv-zfs-replicate.log"
FULL_COMMAND="$0 $*"

DATASET="${1:?dataset required}"
PREFIX="${2:?prefix required}"
DEST="${3:?dest required}"
TYPE="${4:-local}"
REMOTEHOST="${5:-}"
CERTREF="${6:-}"
SSHUSER="${7:-root}"
SSHPORT="${8:-22}"
RECURSIVE="${9:-0}"
RAW="${10:-0}"
shift 10 || true

# Parse optional flags
email_mode=""
email_comment=""
RETENTION=0
USEBOOKMARKS=0
NOSNAPSHOT=0
while [[ $# -gt 0 ]]; do
    case "$1" in
        -r)            RETENTION="$2";  shift 2 ;;
        --bookmarks)   USEBOOKMARKS=1;  shift   ;;
        --no-snapshot) NOSNAPSHOT=1;    shift   ;;
        -e)            email_mode="$2"; shift 2 ;;
        -c)            email_comment="$2"; shift 2 ;;
        *)             shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Output capture + email on exit (compose-style)
# ---------------------------------------------------------------------------
tmpfile=""
if [ -n "${email_mode}" ]; then
    tmpfile=$(mktemp)
    exec > "${tmpfile}" 2>&1
else
    exec > >(tee -a "${LOGFILE}") 2>&1
fi

_send_email() {
    local rc="$1"
    # Always append to logfile when using email mode
    if [ -f "${tmpfile:-}" ]; then
        cat "${tmpfile}" >> "${LOGFILE}"
    fi
    if [ -n "${email_mode}" ] && [ -f "${tmpfile:-}" ]; then
        if [ "${email_mode}" = "always" ] || \
           { [ "${email_mode}" = "onerror" ] && [ "${rc}" -ne 0 ]; }; then
            mail -E -s "ZFS Replication${email_comment:+ - ${email_comment}}" \
                 -a "From: Cron Daemon <root>" root < "${tmpfile}" >/dev/null 2>&1
        fi
        rm -f "${tmpfile}"
    fi
}
trap '_send_email $?' EXIT

# ---------------------------------------------------------------------------
# SSH helpers
# ---------------------------------------------------------------------------
SSH_KEY_DIR="${OMV_SSH_KEYS_DIR:-/etc/ssh}"
SSH_KEY_PREFIX="${OMV_SSH_KEY_PREFIX:-openmediavault-}"

SSH_CMD=""
if [ "${TYPE}" = "remote" ]; then
    SSH_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=accept-new -p ${SSHPORT}"
    if [ -n "${CERTREF}" ]; then
        SSH_OPTS="${SSH_OPTS} -i ${SSH_KEY_DIR}/${SSH_KEY_PREFIX}${CERTREF}"
    fi
    SSH_CMD="ssh ${SSH_OPTS} ${SSHUSER}@${REMOTEHOST}"
fi

dest_exec() {
    if [ -n "${SSH_CMD}" ]; then
        ${SSH_CMD} "$@"
    else
        "$@"
    fi
}

run() {
    echo "$(date -Iseconds): + $*"
    "$@"
}

# ---------------------------------------------------------------------------
# Log the full command for troubleshooting
# ---------------------------------------------------------------------------
echo "$(date -Iseconds): Command: ${FULL_COMMAND}"

# ---------------------------------------------------------------------------
# Create new snapshot on source, or use the most recent existing one
# ---------------------------------------------------------------------------
if [ "${NOSNAPSHOT}" = "1" ]; then
    NEW_SNAP=$(zfs list -H -t snapshot -o name -s creation -r "${DATASET}" \
        | grep "^${DATASET}@${PREFIX}-" | tail -1 || true)
    if [ -z "${NEW_SNAP}" ]; then
        echo "$(date -Iseconds): ERROR: No snapshots found matching ${DATASET}@${PREFIX}-*. Cannot replicate."
        exit 1
    fi
    SNAPNAME="${NEW_SNAP##*@}"
    echo "$(date -Iseconds): Using existing snapshot ${NEW_SNAP} (--no-snapshot mode)"
    if dest_exec zfs list -H -t snapshot "${DEST}@${SNAPNAME}" >/dev/null 2>&1; then
        echo "$(date -Iseconds): Destination already has ${SNAPNAME}, replication is up to date."
        exit 0
    fi
else
    SNAPNAME="${PREFIX}-$(date +%Y%m%d-%H%M%S)"
    NEW_SNAP="${DATASET}@${SNAPNAME}"
    if [ "${RECURSIVE}" = "1" ]; then
        echo "$(date -Iseconds): Creating recursive snapshot ${NEW_SNAP}"
        run zfs snapshot -r "${NEW_SNAP}"
    else
        echo "$(date -Iseconds): Creating snapshot ${NEW_SNAP}"
        run zfs snapshot "${NEW_SNAP}"
    fi
fi

# ---------------------------------------------------------------------------
# Determine send strategy: bookmark-based incremental, snapshot-based, or full
# ---------------------------------------------------------------------------
SEND_FLAGS=""
[ "${RAW}"       = "1" ] && SEND_FLAGS="${SEND_FLAGS} -w"
[ "${RECURSIVE}" = "1" ] && SEND_FLAGS="${SEND_FLAGS} -R"

_incremental_send() {
    local base="$1"
    echo "$(date -Iseconds): Incremental send ${base} -> ${NEW_SNAP} to ${DEST}"
    echo "$(date -Iseconds): + zfs send${SEND_FLAGS:+ ${SEND_FLAGS}} -i ${base} ${NEW_SNAP} | zfs receive -F ${DEST}"
    zfs send ${SEND_FLAGS} -i "${base}" "${NEW_SNAP}" \
        | dest_exec zfs receive -F "${DEST}"
}

sent=0

# Try bookmark-based incremental (preferred when --bookmarks is set).
if [ "${USEBOOKMARKS}" = "1" ]; then
    PREV_BK=$(zfs list -H -t bookmark -o name -r "${DATASET}" \
        | grep "^${DATASET}#${PREFIX}-" | tail -1 || true)
    if [ -n "${PREV_BK}" ]; then
        PREV_SNAPNAME="${PREV_BK##*#}"
        if dest_exec zfs list -H -t snapshot "${DEST}@${PREV_SNAPNAME}" \
                >/dev/null 2>&1; then
            _incremental_send "${PREV_BK}"
            sent=1
        else
            echo "$(date -Iseconds): Destination missing base snapshot ${PREV_SNAPNAME}, trying snapshot-based incremental."
        fi
    fi
fi

# Try snapshot-based incremental.
if [ "${sent}" = "0" ]; then
    PREV_SNAP=$(zfs list -H -t snapshot -o name -s creation -r "${DATASET}" \
        | grep "^${DATASET}@${PREFIX}-" \
        | grep -v "^${NEW_SNAP}$" \
        | tail -1 || true)
    if [ -n "${PREV_SNAP}" ]; then
        PREV_SNAPNAME="${PREV_SNAP##*@}"
        if dest_exec zfs list -H -t snapshot "${DEST}@${PREV_SNAPNAME}" \
                >/dev/null 2>&1; then
            _incremental_send "${PREV_SNAP}"
            sent=1
        else
            echo "$(date -Iseconds): Destination missing base snapshot ${PREV_SNAPNAME}, falling back to full send."
        fi
    fi
fi

# Full send if no incremental base was found.
if [ "${sent}" = "0" ]; then
    echo "$(date -Iseconds): Full send ${NEW_SNAP} -> ${DEST}"
    echo "$(date -Iseconds): + zfs send${SEND_FLAGS:+ ${SEND_FLAGS}} ${NEW_SNAP} | zfs receive -F ${DEST}"
    zfs send ${SEND_FLAGS} "${NEW_SNAP}" | dest_exec zfs receive -F "${DEST}"
fi

# ---------------------------------------------------------------------------
# Post-send: source snapshot pruning (skipped in --no-snapshot mode)
# ---------------------------------------------------------------------------
if [ "${RETENTION}" -gt 0 ] && [ "${NOSNAPSHOT}" = "0" ]; then
    ALL_SNAPS=$(zfs list -H -t snapshot -o name -s creation -r "${DATASET}" \
        | grep "^${DATASET}@${PREFIX}-" || true)
    SNAP_COUNT=$(printf '%s\n' "${ALL_SNAPS}" | grep -c . || true)
    if [ "${SNAP_COUNT}" -gt "${RETENTION}" ]; then
        TO_PRUNE=$(printf '%s\n' "${ALL_SNAPS}" | head -n $(( SNAP_COUNT - RETENTION )))
        while IFS= read -r snap; do
            [ -n "${snap}" ] || continue
            echo "$(date -Iseconds): Pruning old source snapshot ${snap}"
            [ "${RECURSIVE}" = "1" ] && run zfs destroy -r "${snap}" || run zfs destroy "${snap}"
        done <<< "${TO_PRUNE}"
    fi
fi

# ---------------------------------------------------------------------------
# Post-send: bookmark management
# ---------------------------------------------------------------------------
if [ "${USEBOOKMARKS}" = "1" ]; then
    echo "$(date -Iseconds): Creating bookmark ${DATASET}#${SNAPNAME}"
    run zfs bookmark "${NEW_SNAP}" "${DATASET}#${SNAPNAME}"
    OLD_BKS=$(zfs list -H -t bookmark -o name -r "${DATASET}" \
        | grep "^${DATASET}#${PREFIX}-" \
        | grep -v "^${DATASET}#${SNAPNAME}$" || true)
    while IFS= read -r bk; do
        [ -n "${bk}" ] || continue
        echo "$(date -Iseconds): Removing old bookmark ${bk}"
        run zfs destroy "${bk}"
    done <<< "${OLD_BKS}"
fi

echo "$(date -Iseconds): Replication completed successfully."
