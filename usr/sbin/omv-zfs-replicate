#!/bin/bash
# ZFS replication: snapshot source and send to destination (local or remote via SSH).
# Usage: omv-zfs-replicate <dataset> <prefix> <dest> <type> <remotehost>
#                          <certref> <sshuser> <sshport> <recursive> <raw>
#                          [-e always|onerror] [-c comment]
#
#   dataset    - source ZFS dataset (e.g. tank/data)
#   prefix     - snapshot name prefix (e.g. replicate)
#   dest       - destination dataset path (e.g. backup/data)
#   type       - "local" or "remote"
#   remotehost - remote hostname/IP (ignored when type=local)
#   certref    - OMV SSH certificate UUID (ignored when type=local, empty = default key)
#   sshuser    - SSH user on remote (ignored when type=local)
#   sshport    - SSH port on remote (ignored when type=local)
#   recursive  - 1 to snapshot/send recursively, 0 otherwise
#   raw        - 1 to use zfs send -w (raw/encrypted), 0 otherwise
#   -e         - email mode: "always" or "onerror"
#   -c         - email subject comment

set -euo pipefail

LOGFILE="/var/log/omv-zfs-replicate.log"

DATASET="${1:?dataset required}"
PREFIX="${2:?prefix required}"
DEST="${3:?dest required}"
TYPE="${4:-local}"
REMOTEHOST="${5:-}"
CERTREF="${6:-}"
SSHUSER="${7:-root}"
SSHPORT="${8:-22}"
RECURSIVE="${9:-0}"
RAW="${10:-0}"
shift 10 || true

# Parse optional email flags
email_mode=""
email_comment=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        -e) email_mode="$2";    shift 2 ;;
        -c) email_comment="$2"; shift 2 ;;
        *)  shift ;;
    esac
done

# ---------------------------------------------------------------------------
# Output capture + email on exit (compose-style)
# ---------------------------------------------------------------------------
tmpfile=""
if [ -n "${email_mode}" ]; then
    tmpfile=$(mktemp)
    exec > "${tmpfile}" 2>&1
else
    exec > >(tee -a "${LOGFILE}") 2>&1
fi

_send_email() {
    local rc="$1"
    # Always append to logfile when using email mode
    if [ -f "${tmpfile:-}" ]; then
        cat "${tmpfile}" >> "${LOGFILE}"
    fi
    if [ -n "${email_mode}" ] && [ -f "${tmpfile:-}" ]; then
        if [ "${email_mode}" = "always" ] || \
           { [ "${email_mode}" = "onerror" ] && [ "${rc}" -ne 0 ]; }; then
            mail -E -s "ZFS Replication${email_comment:+ - ${email_comment}}" \
                 -a "From: Cron Daemon <root>" root < "${tmpfile}" >/dev/null 2>&1
        fi
        rm -f "${tmpfile}"
    fi
}
trap '_send_email $?' EXIT

# ---------------------------------------------------------------------------
# SSH helpers
# ---------------------------------------------------------------------------
SSH_KEY_DIR="${OMV_SSH_KEYS_DIR:-/etc/ssh}"
SSH_KEY_PREFIX="${OMV_SSH_KEY_PREFIX:-openmediavault-}"

SSH_CMD=""
if [ "${TYPE}" = "remote" ]; then
    SSH_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=accept-new -p ${SSHPORT}"
    if [ -n "${CERTREF}" ]; then
        SSH_OPTS="${SSH_OPTS} -i ${SSH_KEY_DIR}/${SSH_KEY_PREFIX}${CERTREF}"
    fi
    SSH_CMD="ssh ${SSH_OPTS} ${SSHUSER}@${REMOTEHOST}"
fi

dest_exec() {
    if [ -n "${SSH_CMD}" ]; then
        ${SSH_CMD} "$@"
    else
        "$@"
    fi
}

# ---------------------------------------------------------------------------
# Create new snapshot on source
# ---------------------------------------------------------------------------
SNAPNAME="${PREFIX}-$(date +%Y%m%d-%H%M%S)"
NEW_SNAP="${DATASET}@${SNAPNAME}"

if [ "${RECURSIVE}" = "1" ]; then
    echo "$(date -Iseconds): Creating recursive snapshot ${NEW_SNAP}"
    zfs snapshot -r "${NEW_SNAP}"
else
    echo "$(date -Iseconds): Creating snapshot ${NEW_SNAP}"
    zfs snapshot "${NEW_SNAP}"
fi

# ---------------------------------------------------------------------------
# Determine send strategy: incremental from last common snap, or full
# ---------------------------------------------------------------------------
SEND_FLAGS=""
[ "${RAW}"       = "1" ] && SEND_FLAGS="${SEND_FLAGS} -w"
[ "${RECURSIVE}" = "1" ] && SEND_FLAGS="${SEND_FLAGS} -R"

# Find the previous prefix snapshot on source (the one just before the new one).
PREV_SNAP=$(zfs list -H -t snapshot -o name -s creation -r "${DATASET}" \
    | grep "^${DATASET}@${PREFIX}-" \
    | grep -v "^${NEW_SNAP}$" \
    | tail -1 || true)

if [ -n "${PREV_SNAP}" ]; then
    PREV_SNAPNAME="${PREV_SNAP##*@}"
    # Check whether the destination already has that snapshot.
    if dest_exec zfs list -H -t snapshot "${DEST}@${PREV_SNAPNAME}" \
            >/dev/null 2>&1; then
        echo "$(date -Iseconds): Incremental send ${PREV_SNAP} -> ${NEW_SNAP} to ${DEST}"
        zfs send ${SEND_FLAGS} -i "${PREV_SNAP}" "${NEW_SNAP}" \
            | dest_exec zfs receive -F "${DEST}"
        echo "$(date -Iseconds): Replication completed successfully."
        exit 0
    else
        echo "$(date -Iseconds): Destination missing base snapshot ${PREV_SNAPNAME}, falling back to full send."
    fi
fi

echo "$(date -Iseconds): Full send ${NEW_SNAP} -> ${DEST}"
zfs send ${SEND_FLAGS} "${NEW_SNAP}" | dest_exec zfs receive -F "${DEST}"
echo "$(date -Iseconds): Replication completed successfully."
