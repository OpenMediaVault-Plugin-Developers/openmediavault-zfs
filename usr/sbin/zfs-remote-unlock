#!/bin/bash
# Load ZFS encryption keys from remote HTTPS sources defined in /etc/zfs/remote-keys/*.json.
# Each JSON file has the format: {"dataset":"pool/name","url":"https://...","insecure":false}
# This script is invoked by zfs-remote-unlock.service at boot after network and pool import.

set -euo pipefail

META_DIR="/etc/zfs/remote-keys"

[[ -d "$META_DIR" ]] || exit 0

shopt -s nullglob
json_files=("$META_DIR"/*.json)
[[ ${#json_files[@]} -gt 0 ]] || exit 0

for jsonfile in "${json_files[@]}"; do
    dataset=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['dataset'])" "$jsonfile" 2>/dev/null) || continue
    url=$(python3     -c "import json,sys; d=json.load(open(sys.argv[1])); print(d['url'])"     "$jsonfile" 2>/dev/null) || continue
    insecure=$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print('1' if d.get('insecure') else '')" "$jsonfile" 2>/dev/null) || insecure=""

    curl_opts=(-f -s --connect-timeout 15 --max-time 30)
    [[ -n "$insecure" ]] && curl_opts+=(-k)

    echo "zfs-remote-unlock: fetching key for $dataset from $url"
    if key=$(curl "${curl_opts[@]}" "$url" 2>/dev/null); then
        if printf '%s' "$key" | zfs load-key "$dataset" 2>/dev/null; then
            key="" # clear from memory immediately after use
            zfs mount "$dataset" 2>/dev/null || true
            echo "zfs-remote-unlock: unlocked and mounted $dataset"
        else
            key="" # clear from memory on failure too
            echo "zfs-remote-unlock: failed to load key for $dataset (wrong key or already loaded)" >&2
        fi
    else
        echo "zfs-remote-unlock: failed to fetch key for $dataset from $url" >&2
    fi
done
