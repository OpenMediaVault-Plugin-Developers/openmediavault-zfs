msgid ""
"'Snapshots' keeps the N most recent; time units delete snapshots older than "
"N days/weeks/months/years."
msgstr "'ສະແນັບຊັອດ' ຈະເກັບຮັກສາ N ລາຍການຫຼ້າສຸດ; ຫົວໜ່ວຍເວລາຈະລຶບສະແນັບຊັອດທີ່ເກົ່າກວ່າ N ມື້/ອາທິດ/ເດືອນ/ປີ."

msgid "A different name must be specified."
msgstr "ຕ້ອງລະບຸຊື່ທີ່ແຕກຕ່າງກັນ."

msgid "ARC Stats"
msgstr "ສະຖິຕິ ARC"

msgid "Add"
msgstr "ເພີ່ມ"

msgid "Add Special Device"
msgstr "ເພີ່ມອຸປະກອນພິເສດ"

msgid "Add cache / log / spare / special"
msgstr "ເພີ່ມ cache / log / spare / special"

msgid "Add encrypted filesystem"
msgstr "ເພີ່ມລະບົບໄຟລ໌ທີ່ມີການເຂົ້າລະຫັດ"

msgid "Add filesystem"
msgstr "ເພີ່ມລະບົບໄຟລ໌"

msgid "Add new"
msgstr "ເພີ່ມໃໝ່"

msgid "Add new + delete missing"
msgstr "ເພີ່ມໃໝ່ + ລຶບອັນທີ່ຫາຍໄປ"

msgid "Add pool"
msgstr "ເພີ່ມພູລ (Pool)"

msgid "Add snapshot"
msgstr "ເພີ່ມສະແນັບຊັອດ"

msgid "Add volume"
msgstr "ເພີ່ມວໍລຸມ (Volume)"

msgid "Adding filesystem ..."
msgstr "ກຳລັງເພີ່ມລະບົບໄຟລ໌ ..."

msgid "Adding missing ZFS mntent entries ..."
msgstr "ກຳລັງເພີ່ມລາຍການ ZFS mntent ທີ່ຫາຍໄປ ..."

msgid "Adding snapshot ..."
msgstr "ກຳລັງເພີ່ມສະແນັບຊັອດ ..."

msgid "Adding volume ..."
msgstr "ກຳລັງເພີ່ມວໍລຸມ ..."

msgid ""
"After each successful send, create a ZFS bookmark as the incremental base. "
"Allows pruning source snapshots to 1 while maintaining incremental "
"replication. Not compatible with 'Recursive' (ZFS does not support recursive"
" sends from a bookmark) and not needed when 'Use existing snapshots' is "
"enabled."
msgstr "ຫຼັງຈາກການສົ່ງສຳເລັດແຕ່ລະຄັ້ງ, ໃຫ້ສ້າງບຸກມາກ ZFS ເພື່ອເປັນຖານການເພີ່ມຂຶ້ນ. ຊ່ວຍໃຫ້ສາມາດຫຼຸດຈຳນວນສະແນັບຊັອດຕົ້ນທາງເຫຼືອ 1 ໃນຂະນະທີ່ຍັງຮັກສາການຈຳລອງຂໍ້ມູນແບບສ່ວນເພີ່ມ (incremental replication) ໄດ້. ບໍ່ສາມາດໃຊ້ຮ່ວມກັບ 'Recursive' (ZFS ບໍ່ຮອງຮັບການສົ່ງແບບ recursive ຈາກບຸກມາກ) ແລະ ບໍ່ຈຳເປັນຕ້ອງໃຊ້ ເມື່ອເປີດໃຊ້ 'Use existing snapshots'."

msgid "Algorithm"
msgstr "ອັນກໍຣິທຶມ"

msgid "All snapshots deleted."
msgstr "ລຶບສະແນັບຊັອດທັງໝົດແລ້ວ."

msgid "Alloc"
msgstr "Alloc"

msgid ""
"Allow self-signed or untrusted certificates. Use only on trusted local "
"networks."
msgstr "ອະນຸຍາດໃບຢັ້ງຢືນທີ່ເຊັນດ້ວຍຕົນເອງ ຫຼື ບໍ່ໜ້າເຊື່ອຖື. ໃຊ້ສະເພາະໃນເຄືອຂ່າຍທ້ອງຖິ່ນທີ່ໜ້າເຊື່ອຖືເທົ່ານັ້ນ."

msgid "Anchor (existing device or RAIDZ vdev)"
msgstr "Anchor (ອຸປະກອນທີ່ມີຢູ່ ຫຼື RAIDZ vdev)"

msgid "April"
msgstr "ເມສາ"

msgid "Are you sure you want to add this device to the pool?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການເພີ່ມອຸປະກອນນີ້ເຂົ້າໃນພູລ?"

msgid ""
"Are you sure you want to cancel the vdev removal? Data evacuation will stop "
"and the vdev will remain in the pool."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຍົກເລີກການຖອນ vdev? ການຍ້າຍຂໍ້ມູນຈະຢຸດລົງ ແລະ vdev ຈະຍັງຄົງຢູ່ໃນພູລ."

msgid ""
"Are you sure you want to delete '{{ _selected[0].path }}' from this dataset "
"and all child datasets?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບ '{{ _selected[0].path }}' ຈາກຊຸດຂໍ້ມູນນີ້ ແລະ ຊຸດຂໍ້ມູນລູກທັງໝົດ?"

msgid ""
"Are you sure you want to delete ALL snapshots on the parent dataset '{{ "
"_selected[0].parent }}'?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບສະແນັບຊັອດທັງໝົດໃນຊຸດຂໍ້ມູນແມ່ '{{ _selected[0].parent }}'?"

msgid "Are you sure you want to delete the selected snapshot(s)?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບສະແນັບຊັອດທີ່ເລືອກ?"

msgid ""
"Are you sure you want to delete this snapshot and all earlier snapshots on "
"the same dataset?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບສະແນັບຊັອດນີ້ ແລະ ສະແນັບຊັອດກ່ອນໜ້ານີ້ທັງໝົດໃນຊຸດຂໍ້ມູນດຽວກັນ?"

msgid ""
"Are you sure you want to delete this snapshot and all later snapshots on the"
" same dataset?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບສະແນັບຊັອດນີ້ ແລະ ສະແນັບຊັອດຫຼັງຈາກນີ້ທັງໝົດໃນຊຸດຂໍ້ມູນດຽວກັນ?"

msgid "Are you sure you want to delete?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການລຶບ?"

msgid "Are you sure you want to detach this device from the pool?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຖອດອຸປະກອນນີ້ອອກຈາກພູລ?"

msgid ""
"Are you sure you want to disable auto-unlock? The saved key or remote URL "
"configuration will be removed and you will need to enter the passphrase "
"manually after each reboot."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການປິດການປົດລັອກອັດຕະໂນມັດ? ຄີທີ່ບັນທຶກໄວ້ ຫຼື ການຕັ້ງຄ່າ URL ທາງໄກຈະຖືກລຶບອອກ ແລະ ທ່ານຈະຕ້ອງປ້ອນວະລີຜ່ານດ້ວຍຕົນເອງຫຼັງຈາກການເປີດເຄື່ອງໃໝ່ທຸກຄັ້ງ."

msgid "Are you sure you want to export?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການສົ່ງອອກ (Export)?"

msgid ""
"Are you sure you want to promote this dataset? This detaches the clone from "
"its origin snapshot dependency."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຍົກລະດັບ (Promote) ຊຸດຂໍ້ມູນນີ້? ການເຮັດແບບນີ້ຈະຕັດການເຊື່ອມໂຍງຂອງຕົວສຳເນົາ (Clone) ອອກຈາກສະແນັບຊັອດຕົ້ນສະບັບ."

msgid ""
"Are you sure you want to replace this device? Resilvering will begin "
"immediately."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການປ່ຽນອຸປະກອນນີ້? ການ Resilvering ຈະເລີ່ມຕົ້ນທັນທີ."

msgid "Are you sure you want to rollback to this snapshot?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຍ້ອນຄືນ (Rollback) ໄປຫາສະແນັບຊັອດນີ້?"

msgid ""
"Are you sure you want to start a TRIM operation on this pool? This is only "
"meaningful for SSD-backed pools."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການເລີ່ມການເຮັດວຽກ TRIM ໃນພູລນີ້? ອັນນີ້ມີຜົນສະເພາະກັບພູລທີ່ໃຊ້ SSD ເທົ່ານັ້ນ."

msgid "Are you sure you want to start a scrub?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການເລີ່ມການສະກຣັບ (Scrub)?"

msgid "Are you sure you want to stop the scrub?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຢຸດການສະກຣັບ?"

msgid "Are you sure you want to take this device offline?"
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການໃຫ້ອຸປະກອນນີ້ອອບລາຍ?"

msgid ""
"Are you sure you want to unload the encryption key? The dataset will become "
"inaccessible until it is unlocked again."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການຖອນຄີການເຂົ້າລະຫັດ? ຊຸດຂໍ້ມູນຈະບໍ່ສາມາດເຂົ້າເຖິງໄດ້ຈົນກວ່າຈະມີການປົດລັອກອີກຄັ້ງ."

msgid ""
"Are you sure you want to upgrade this pool? This enables new feature flags "
"and cannot be undone. The pool will no longer be accessible by older ZFS "
"versions."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່ວ່າຕ້ອງການອັບເກຣດພູລນີ້? ອັນນີ້ຈະເປີດໃຊ້ຟີເຈີໃໝ່ ແລະ ບໍ່ສາມາດຍ້ອນກັບໄດ້. ZFS ເວີຊັນເກົ່າຈະບໍ່ສາມາດເຂົ້າເຖິງພູລນີ້ໄດ້ອີກຕໍ່ໄປ."

msgid ""
"Are you sure? For a mirror or stripe pool this attaches the new device to "
"the selected existing device, extending the mirror or converting a stripe "
"device into a 2-way mirror (irreversible without full pool recreation). For "
"a RAIDZ pool this expands the selected RAIDZ vdev by adding one device, "
"permanently increasing its width."
msgstr "ທ່ານແນ່ໃຈຫຼືບໍ່? ສຳລັບພູລແບບ mirror ຫຼື stripe ອັນນີ້ຈະເປັນການເຊື່ອມຕໍ່ອຸປະກອນໃໝ່ເຂົ້າກັບອຸປະກອນທີ່ມີຢູ່, ເພື່ອຂະຫຍາຍ mirror ຫຼື ປ່ຽນ stripe ໃຫ້ເປັນ 2-way mirror (ບໍ່ສາມາດຍ້ອນກັບໄດ້ ໂດຍບໍ່ສ້າງພູລໃໝ່ທັງໝົດ). ສຳລັບພູລແບບ RAIDZ ອັນນີ້ຈະຂະຫຍາຍ RAIDZ vdev ທີ່ເລືອກໂດຍການເພີ່ມອຸປະກອນໜຶ່ງຕົວ, ເຊິ່ງຈະເພີ່ມຄວາມກວ້າງຂອງມັນຢ່າງຖາວອນ."

msgid "Ashift value"
msgstr "ຄ່າ Ashift"

msgid "At least five devices are required."
msgstr "ຕ້ອງການອຸປະກອນຢ່າງໜ້ອຍຫ້າຕົວ."

msgid "At least four devices are required."
msgstr "ຕ້ອງການອຸປະກອນຢ່າງໜ້ອຍສີ່ຕົວ."

msgid "At least three devices are required."
msgstr "ຕ້ອງການອຸປະກອນຢ່າງໜ້ອຍສາມຕົວ."

msgid "At least two devices are required."
msgstr "ຕ້ອງການອຸປະກອນຢ່າງໜ້ອຍສອງຕົວ."

msgid "At reboot"
msgstr "ເມື່ອເປີດເຄື່ອງໃໝ່"

msgid "Attach device"
msgstr "ເຊື່ອມຕໍ່ອຸປະກອນ"

msgid "August"
msgstr "ສິງຫາ"

msgid "Auto-unlock"
msgstr "ປົດລັອກອັດຕະໂນມັດ"

msgid "Auto-unlock at boot"
msgstr "ປົດລັອກອັດຕະໂນມັດເມື່ອເປີດເຄື່ອງ"

msgid "Auto-unlock disabled."
msgstr "ປິດການປົດລັອກອັດຕະໂນມັດແລ້ວ."

msgid ""
"Auto-unlock enabled. The key will be loaded from the local keyfile at boot."
msgstr "ເປີດການປົດລັອກອັດຕະໂນມັດແລ້ວ. ຄີຈະຖືກໂຫຼດຈາກໄຟລ໌ຄີໃນເຄື່ອງເມື່ອເປີດເຄື່ອງ."

msgid "Available"
msgstr "ຫວ່າງ/ໃຊ້ໄດ້"

msgid "Basic"
msgstr "ພື້ນຖານ"

msgid "Bulk Delete"
msgstr "ລຶບຈຳນວນຫຼາຍ"

msgid "By ID"
msgstr "ຕາມ ID"

msgid "By Path"
msgstr "ຕາມ Path"

msgid "Cache (L2ARC)"
msgstr "Cache (L2ARC)"

msgid "Cancel vdev removal"
msgstr "ຍົກເລີກການຖອນ vdev"

msgid "Cancelling vdev removal ..."
msgstr "ກຳລັງຍົກເລີກການຖອນ vdev ..."

msgid "Cap"
msgstr "ຄວາມຈຸ"

msgid "Case sensitivity"
msgstr "ການຈຳແນກຕົວອັກສອນພິມໃຫຍ່-ນ້ອຍ"

msgid "Certain date"
